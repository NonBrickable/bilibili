<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//ibatis.apache.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!-- mapper 为根元素节点， 一个namespace对应一个dao -->
<mapper namespace="com.bilibili.dao.AuthRoleElementOperationDao">
    <resultMap id="AuthElementOperationResultMap" type="com.bilibili.pojo.auth.AuthRoleElementOperation">
        <id column="id" property="id"/>
        <id column="role_id" property="roleId"/>
        <id column="element_id" property="elementId"/>
        <association property="authElementOperation" javaType="com.bilibili.pojo.auth.AuthElementOperation">
            <id column="element_name" property="elementName"/>
            <id column="element_code" property="elementCode"/>
            <id column="operation_type" property="operationType"/>
        </association>
    </resultMap>
    <select id="getRoleElementOperationsByRoleIds" parameterType="list" resultMap="AuthElementOperationResultMap">
        select areo.*, aeo.element_name, aeo.element_code, aeo.operation_type
        from t_auth_role_element_operation areo
        left join t_auth_element_operation aeo
        on areo.element_id = aeo.id
        where areo.role_id in
        <foreach collection="roleIdList" index="index" item="roleId" open="(" close=")" separator=",">
            #{roleId}
        </foreach>
    </select>

</mapper>